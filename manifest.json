{
  "manifest_version": 3,
  "name": "Ozon Operations Injector",
  "version": "1.0",

  "permissions": ["storage", "tabs"],

  "host_permissions": [
    "https://finance.ozon.ru/*",
    "https://files.finance.ozon.ru/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["https://finance.ozon.ru/*"],
      "js": ["bridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://finance.ozon.ru/*"],
      "js": ["config.js", "content.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}